FROM node:20-slim

LABEL maintainer="forge-agent" \
      forge-agent="true"

# System dependencies (full stack: Node + Python + build tools)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    sqlite3 \
    jq \
    curl \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# tree-sitter CLI for symbol extraction
RUN npm install -g tree-sitter-cli@0.22 2>/dev/null || true

# Python tooling
RUN pip install --no-cache-dir --break-system-packages \
    ruff \
    mypy \
    pytest \
    2>/dev/null || true

# Create workspace directories
RUN mkdir -p /workspace /output/patches /knowledge /config /graph /entrypoint /home/forge/.local/bin /home/forge/.local/share /home/forge/.claude

# Copy entrypoint scripts (build context = forge-containers/)
COPY agent-entrypoint.js /entrypoint/agent-entrypoint.js
COPY agent-verifier.js /entrypoint/agent-verifier.js

# Non-root user for safety — home at /home/forge for Claude CLI mount
RUN groupadd -r forge && useradd -r -g forge -d /home/forge forge
RUN chown -R forge:forge /workspace /output /knowledge /home/forge

WORKDIR /workspace

# Default: run agent entrypoint
ENTRYPOINT ["node", "/entrypoint/agent-entrypoint.js"]
