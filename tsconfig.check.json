{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "forge-cli/lib/logger.js",
    "forge-session/otel.js",
    "forge-session/redactor.js",
    "forge-session/metrics-batcher.js",
    "forge-verify/cache.js",
    "forge-graph/incremental.js",
    "forge-assess/tokenizers/heuristic.js",
    "forge-assess/tokenizers/index.js"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.js",
    "**/*.test.cjs"
  ]
}
